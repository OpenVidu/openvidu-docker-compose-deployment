# Configure here the domain name you want to use for OpenVidu.
DOMAIN_NAME=

# LiveKit API Key and Secret.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Dashboard admin user and password.
DASHBOARD_ADMIN_USERNAME=
DASHBOARD_ADMIN_PASSWORD=

# Redis password.
REDIS_PASSWORD=

# Minio configuration.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Mongo configuration.
MONGO_ADMIN_USERNAME=
MONGO_ADMIN_PASSWORD=

# Grafana
GRAFANA_ADMIN_USERNAME=
GRAFANA_ADMIN_PASSWORD=

# Meet Initial Admin User and Password
MEET_INITIAL_ADMIN_USER=
MEET_INITIAL_ADMIN_PASSWORD=
# Meet Initial API Key (optional, if not set, no API key will be created)
MEET_INITIAL_API_KEY=

# OpenVidu Meet base path
MEET_BASE_PATH=/meet
